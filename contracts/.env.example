# Copy to repo root `.env` (Hardhat loads ../.env) or place here.

# Polygon Amoy deploy
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Local deploy only — seeds demo institutions + transcripts (needs hardhat node accounts)
# SEED=true
