# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Pinata IPFS ───────────────────────────────────────────────────────────────
# Get from: https://app.pinata.cloud → API Keys → New Key
VITE_PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=your-gateway.mypinata.cloud

# ── Chain (optional override) ─────────────────────────────────────────────────
# VITE_CHAIN=amoy    # set to 'amoy' to use Polygon Amoy testnet
